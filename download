import * as THREE from 'three';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
import { CreatureStore } from './core/CreatureStore';
import { createDefaultCreature, PRESETS } from './core/presets';
import type { DebugFlags, LocomotionTuning } from './core/types';
import { RigBuilder } from './animation/RigBuilder';
import { LocomotionController, type LocomotionSnapshot } from './animation/LocomotionController';
import { PhysicsWorld } from './physics/PhysicsWorld';
import { CreatureRenderer } from './render/CreatureRenderer';
import { DebugRenderer } from './render/DebugRenderer';
import { TestArena } from './render/TestArena';
import { EditorController, type PalettePart } from './editor/EditorController';
import { InputController } from './editor/InputController';
import { UI, type UIActions } from './ui/UI';
import { uid } from './utils/math';

const DEFAULT_DEBUG: DebugFlags = {
  skeleton: false,
  colliders: false,
  centreOfMass: true,
  supportPolygon: true,
  footTargets: false,
  raycasts: false,
  gaitPhase: false,
  jointLimits: false,
  bodyVelocity: false,
  frameRate: true,
};

const DEFAULT_TUNING: LocomotionTuning = {
  stepLength: 0.46,
  stepHeight: 0.2,
  stepDuration: 0.66,
  stanceRatio: 0.68,
  bodySpring: 8.5,
  balanceCorrection: 1.1,
  armSwing: 0.82,
  tailCounterbalance: 0.8,
  maxSlopeDegrees: 30,
  maxStepHeight: 0.38,
};

export class App {
  private readonly scene = new THREE.Scene();
  private readonly camera = new THREE.PerspectiveCamera(45, 1, 0.05, 180);
  private readonly webgl = new THREE.WebGLRenderer({ antialias: true, powerPreference: 'high-performance' });
  private readonly physics = new PhysicsWorld();
  private readonly store = new CreatureStore(createDefaultCreature());
  private readonly rigBuilder = new RigBuilder();
  private readonly input = new InputController();
  private readonly debugFlags: DebugFlags = { ...DEFAULT_DEBUG };
  private readonly tuning: LocomotionTuning = { ...DEFAULT_TUNING };
  private ui!: UI;
  private orbit!: OrbitControls;
  private creatureRenderer!: CreatureRenderer;
  private debugRenderer!: DebugRenderer;
  private arena!: TestArena;
  private editor!: EditorController;
  private locomotion!: LocomotionController;
  private mode: 'edit' | 'test' = 'edit';
  private currentPreset: keyof typeof PRESETS = 'biped';
  private followCamera = true;
  private clickToMove = false;
  private readonly clock = new THREE.Clock();
  private lastSnapshot: LocomotionSnapshot | null = null;
  private physicsMs = 0;
  private frames = 0;
  private fps = 60;
  private fpsAccumulator = 0;
  private readonly clickRay = new THREE.Raycaster();
  private readonly pointer = new THREE.Vector2();

  async initialise(): Promise<void> {
    await this.physics.initialise();
    this.configureScene();
    this.ui = new UI(this.createUIActions(), this.debugFlags, this.tuning);
    this.configureRenderer();

    this.orbit = new OrbitControls(this.camera, this.webgl.domElement);
    this.orbit.enableDamping = true;
    this.orbit.dampingFactor = 0.08;
    this.orbit.target.set(0, 1.55, 0);
    this.orbit.minDistance = 3.4;
    this.orbit.maxDistance = 11;
    this.orbit.maxPolarAngle = Math.PI * 0.49;

    this.creatureRenderer = new CreatureRenderer(this.scene);
    this.debugRenderer = new DebugRenderer(this.scene, this.debugFlags);
    this.arena = new TestArena(this.scene, this.physics);
    this.arena.build();
    this.arena.editorPlatform.position.y = -0.16;
    this.arena.colliderDebug.visible = this.debugFlags.colliders;

    this.locomotion = new LocomotionController(
      this.physics,
      this.creatureRenderer,
      this.debugRenderer,
      this.tuning,
    );
    this.editor = new EditorController(
      this.camera,
      this.webgl.domElement,
      this.scene,
      this.orbit,
      this.creatureRenderer,
      this.store,
    );
    this.editor.onSelection((selection) => this.ui.renderInspector(this.store.value, selection));

    this.bindViewportInteractions();
    this.store.subscribe((creature) => {
      const rig = this.rigBuilder.build(creature);
      this.creatureRenderer.rebuild(creature, rig);
      this.locomotion.setCreature(creature);
      this.editor.reattachSelection();
      this.ui.setCreature(creature);
      this.ui.setHistory(this.store.canUndo, this.store.canRedo);
      const stats = this.locomotion
        .getBalanceSolver()
        .estimateStats(creature, this.locomotion.getGaitPlan());
      this.ui.renderStats(stats);
      this.ui.renderInspector(creature, this.editor.getSelection());
    });

    this.setMode('edit');
    this.onResize();
    window.addEventListener('resize', this.onResize);
    this.webgl.setAnimationLoop(this.animate);
  }

  private configureScene(): void {
    this.scene.background = new THREE.Color('#a9d6e7');
    this.scene.fog = new THREE.Fog('#b7dce8', 18, 48);
    const hemi = new THREE.HemisphereLight('#effbff', '#476443', 2.2);
    const sun = new THREE.DirectionalLight('#fff1d4', 3.1);
    sun.position.set(-7, 12, 7);
    sun.castShadow = true;
    sun.shadow.mapSize.set(2048, 2048);
    sun.shadow.camera.left = -12;
    sun.shadow.camera.right = 12;
    sun.shadow.camera.top = 12;
    sun.shadow.camera.bottom = -12;
    sun.shadow.camera.near = 0.5;
    sun.shadow.camera.far = 40;
    sun.shadow.bias = -0.0004;
    const rim = new THREE.DirectionalLight('#8fd6ff', 1.15);
    rim.position.set(8, 5, -8);
    this.scene.add(hemi, sun, rim);
  }

  private configureRenderer(): void {
    this.webgl.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));
    this.webgl.shadowMap.enabled = true;
    this.webgl.shadowMap.type = THREE.PCFSoftShadowMap;
    this.webgl.outputColorSpace = THREE.SRGBColorSpace;
    this.webgl.toneMapping = THREE.ACESFilmicToneMapping;
    this.webgl.toneMappingExposure = 1.03;
    this.ui.canvasHost.append(this.webgl.domElement);
  }

  private createUIActions(): UIActions {
    return {
      onMode: (mode) => this.setMode(mode),
      onPreset: (key) => {
        const factory = PRESETS[key];
        if (factory) {
          this.currentPreset = key;
          this.editor?.select(null, null);
          this.store.replace(factory(), 'preset');
          this.ui.toast(`Loaded ${key.replace(/([A-Z])/g, ' $1').toLowerCase()} preset`);
        }
      },
      onUndo: () => this.store.undo(),
      onRedo: () => this.store.redo(),
      onSave: () => this.saveCreature(),
      onResetCreature: () => {
        const factory = PRESETS[this.currentPreset];
        if (factory) {
          this.editor.select(null, null);
          this.store.replace(factory(), 'reset creature');
          this.ui.toast('Creature reset to its starter anatomy');
        }
      },
      onLoad: (file) => void this.loadCreature(file),
      onSymmetry: (enabled) => this.store.update((draft) => { draft.symmetry = enabled; }, 'symmetry'),
      onTransformMode: (mode) => this.editor.setTransformMode(mode),
      onDuplicate: () => this.editor.duplicateSelected(),
      onMirror: () => this.editor.mirrorSelected(),
      onDelete: () => this.editor.deleteSelected(),
      onCreatureName: (name) => this.store.update((draft) => { draft.name = name; }, 'rename'),
      onBodyChange: (id, field, value) => this.updateBody(id, field, value),
      onAddBodySegment: (id) => this.addBodySegment(id),
      onLimbRole: (id, role) => this.store.update((draft) => {
        const limb = draft.limbs.find((entry) => entry.id === id);
        if (limb) limb.role = role;
      }, 'limb role'),
      onLimbSegment: (id, segmentIndex, field, value) => this.store.update((draft) => {
        const segment = draft.limbs.find((entry) => entry.id === id)?.segments[segmentIndex];
        if (segment) segment[field] = value;
      }, 'limb segment'),
      onAddLimbSegment: (id) => this.store.update((draft) => {
        const limb = draft.limbs.find((entry) => entry.id === id);
        if (!limb || limb.segments.length >= 5) return;
        const previous = limb.segments[limb.segments.length - 1];
        limb.segments.push({
          id: `${id}-seg-${uid('joint')}`,
          length: previous?.length ?? 0.42,
          radius: Math.max(0.05, (previous?.radius ?? 0.1) * 0.88),
          taper: 0.82,
        });
      }, 'add limb joint'),
      onRemoveLimbSegment: (id) => this.store.update((draft) => {
        const limb = draft.limbs.find((entry) => entry.id === id);
        if (limb && limb.segments.length > 1) limb.segments.pop();
      }, 'remove limb joint'),
      onBendDirection: (id, axis, value) => this.store.update((draft) => {
        const limb = draft.limbs.find((entry) => entry.id === id);
        if (limb) limb.bendDirection[axis] = value;
      }, 'bend direction'),
      onEffectorScale: (id, axis, value) => this.store.update((draft) => {
        const limb = draft.limbs.find((entry) => entry.id === id);
        if (limb) limb.endEffectorScale[axis] = value;
      }, 'effector size'),
      onDebug: (key, enabled) => {
        this.debugFlags[key] = enabled;
        this.debugRenderer.setFlags(this.debugFlags);
        this.arena.colliderDebug.visible = this.debugFlags.colliders;
        if (key === 'frameRate') this.ui.setPerformanceVisible(enabled);
      },
      onTuning: (key, value) => {
        this.tuning[key] = value;
        if (key === 'stanceRatio' || key === 'stepDuration') this.locomotion.replan();
      },
      onResetPosition: () => this.locomotion.resetPosition(),
      onRecover: () => this.locomotion.recover(),
      onFollowCamera: (enabled) => { this.followCamera = enabled; },
      onClickToMove: (enabled) => { this.clickToMove = enabled; },
      onResetObjects: () => this.physics.resetDynamicBodies(),
    };
  }

  private updateBody(id: string, field: 'name' | 'scaleX' | 'scaleY' | 'scaleZ', value: string | number): void {
    this.store.update((draft) => {
      const body = draft.body.find((entry) => entry.id === id);
      if (!body) return;
      if (field === 'name') body.name = String(value);
      else if (field === 'scaleX') body.scale.x = Number(value);
      else if (field === 'scaleY') body.scale.y = Number(value);
      else body.scale.z = Number(value);
    }, 'body property');
  }

  private addBodySegment(parentId: string): void {
    const parent = this.store.value.body.find((entry) => entry.id === parentId);
    if (!parent) return;
    const id = uid(parent.kind === 'tail' ? 'tail' : 'torso');
    this.store.update((draft) => {
      const kind = parent.kind === 'tail' ? 'tail' : parent.kind === 'neck' ? 'neck' : 'torso';
      draft.body.push({
        id,
        kind,
        name: kind === 'tail' ? 'Tail segment' : kind === 'neck' ? 'Neck segment' : 'Torso segment',
        position: {
          x: parent.position.x,
          y: parent.position.y + (kind === 'neck' ? parent.scale.y * 1.15 : 0.08),
          z: parent.position.z + (kind === 'tail' ? -parent.scale.z * 1.45 : parent.scale.z * 1.45),
        },
        rotation: { ...parent.rotation },
        scale: {
          x: Math.max(0.14, parent.scale.x * 0.84),
          y: Math.max(0.14, parent.scale.y * 0.84),
          z: Math.max(0.14, parent.scale.z * 0.84),
        },
        parentId,
        massDensity: kind === 'tail' ? 0.42 : 1,
      });
    }, 'add body segment');
    this.editor.select('body', id);
  }

  private setMode(mode: 'edit' | 'test'): void {
    this.mode = mode;
    this.ui.clearArmedPart();
    this.ui.setMode(mode);
    this.arena.setMode(mode);
    this.editor.setEnabled(mode === 'edit');
    this.input.setEnabled(mode === 'test');
    this.locomotion.setActive(mode === 'test');
    if (mode === 'edit') {
      this.locomotion.resetPosition();
      this.camera.position.set(5.4, 3.8, 6.5);
      this.orbit.target.set(0, 1.55, 0);
      this.orbit.minDistance = 3.2;
      this.orbit.maxDistance = 10;
      this.orbit.enablePan = true;
      this.editor.reattachSelection();
    } else {
      this.locomotion.resetPosition();
      this.camera.position.set(5.8, 3.8, 7.5);
      this.orbit.target.set(0, 1.35, 0);
      this.orbit.minDistance = 3.4;
      this.orbit.maxDistance = 12;
      this.orbit.enablePan = false;
    }
    this.orbit.update();
  }

  private bindViewportInteractions(): void {
    this.webgl.domElement.addEventListener('pointerdown', (event) => {
      if (this.mode !== 'edit' || event.button !== 0) return;
      const part = this.ui.getArmedPart();
      if (!part) return;
      const hit = this.editor.getAttachmentAt(event.clientX, event.clientY, part);
      if (hit) {
        event.preventDefault();
        event.stopImmediatePropagation();
        this.editor.addPalettePart(part, hit);
        this.ui.clearArmedPart();
        this.ui.setDropActive(false);
      } else {
        this.ui.toast('Tap a valid highlighted body surface.', 'error');
      }
    }, { capture: true });
    this.ui.viewport.addEventListener('dragover', (event) => {
      if (this.mode !== 'edit') return;
      event.preventDefault();
      if (event.dataTransfer) event.dataTransfer.dropEffect = 'copy';
      const part = (this.ui.getDraggedPart() || event.dataTransfer?.getData('application/x-creature-part') || event.dataTransfer?.getData('text/plain')) as PalettePart;
      this.ui.setDropActive(Boolean(this.editor.previewPalettePart(event.clientX, event.clientY, part)));
    });
    this.ui.viewport.addEventListener('dragleave', (event) => {
      if (!this.ui.viewport.contains(event.relatedTarget as Node | null)) {
        this.editor.clearPalettePreview();
        this.ui.setDropActive(false);
      }
    });
    this.ui.viewport.addEventListener('drop', (event) => {
      if (this.mode !== 'edit') return;
      event.preventDefault();
      const part = (this.ui.getDraggedPart() || event.dataTransfer?.getData('application/x-creature-part') || event.dataTransfer?.getData('text/plain')) as PalettePart;
      const hit = this.editor.getAttachmentAt(event.clientX, event.clientY, part);
      if (part && hit) this.editor.addPalettePart(part, hit);
      else this.ui.toast('Move the part onto a valid highlighted body surface.', 'error');
      this.editor.clearPalettePreview();
      this.ui.setDropActive(false);
    });
    this.webgl.domElement.addEventListener('click', (event) => {
      if (this.mode !== 'test' || !this.clickToMove) return;
      const rect = this.webgl.domElement.getBoundingClientRect();
      this.pointer.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
      this.pointer.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
      this.clickRay.setFromCamera(this.pointer, this.camera);
      const hit = this.physics.raycast(this.clickRay.ray.origin, this.clickRay.ray.direction, 100);
      if (hit) this.locomotion.setClickTarget(hit.point);
    });
  }

  private saveCreature(): void {
    const blob = new Blob([this.store.toJson()], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `${this.store.value.name.toLowerCase().replace(/[^a-z0-9]+/g, '-') || 'creature'}.creature.json`;
    link.click();
    URL.revokeObjectURL(url);
    this.ui.toast('Creature saved as JSON');
  }

  private async loadCreature(file: File): Promise<void> {
    try {
      this.editor.select(null, null);
      this.store.fromJson(await file.text());
      this.ui.toast('Creature loaded');
    } catch (error) {
      this.ui.toast(error instanceof Error ? error.message : 'Could not load creature', 'error');
    }
  }

  private animate = (): void => {
    const delta = Math.min(0.05, this.clock.getDelta());
    this.physicsMs = this.physics.step(delta);
    this.locomotion.setInput(this.input.getInput());
    const previousTarget = this.orbit.target.clone();
    this.lastSnapshot = this.locomotion.update(delta, this.camera);

    if (this.mode === 'test' && this.followCamera && this.lastSnapshot) {
      const desiredTarget = this.lastSnapshot.bodyPosition.clone().add(new THREE.Vector3(0, 1.35, 0));
      const nextTarget = this.orbit.target.clone().lerp(desiredTarget, 1 - Math.exp(-6 * delta));
      this.camera.position.add(nextTarget.clone().sub(previousTarget));
      this.orbit.target.copy(nextTarget);
    }
    this.orbit.update();
    this.webgl.render(this.scene, this.camera);

    this.frames += 1;
    this.fpsAccumulator += delta;
    if (this.fpsAccumulator >= 0.35) {
      this.fps = this.frames / this.fpsAccumulator;
      this.frames = 0;
      this.fpsAccumulator = 0;
      if (this.lastSnapshot) this.ui.updateRuntime(this.lastSnapshot);
      this.ui.updatePerformance(this.fps, this.physicsMs);
    }
  };

  private onResize = (): void => {
    if (!this.ui) return;
    const width = this.ui.canvasHost.clientWidth;
    const height = this.ui.canvasHost.clientHeight;
    this.camera.aspect = width / Math.max(1, height);
    this.camera.updateProjectionMatrix();
    this.webgl.setSize(width, height, false);
  };
}
