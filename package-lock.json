import * as THREE from 'three';
import type { CreatureDefinition, DebugFlags, LimbRuntimePose } from '../core/types';
import type { BalanceResult } from '../animation/BalanceSolver';
import { v3 } from '../utils/math';

export class DebugRenderer {
  readonly group = new THREE.Group();
  private readonly comGroup = new THREE.Group();
  private readonly supportGroup = new THREE.Group();
  private readonly feetGroup = new THREE.Group();
  private readonly skeletonGroup = new THREE.Group();
  private readonly rayGroup = new THREE.Group();
  private readonly velocityGroup = new THREE.Group();
  private readonly jointLimitGroup = new THREE.Group();
  private flags: DebugFlags;

  constructor(scene: THREE.Scene, initialFlags: DebugFlags) {
    this.flags = { ...initialFlags };
    this.group.name = 'Debug overlays';
    this.group.add(
      this.comGroup,
      this.supportGroup,
      this.feetGroup,
      this.skeletonGroup,
      this.rayGroup,
      this.velocityGroup,
      this.jointLimitGroup,
    );
    scene.add(this.group);
  }

  setFlags(flags: DebugFlags): void {
    this.flags = { ...flags };
    this.applyVisibility();
  }

  update(
    creature: CreatureDefinition,
    root: THREE.Object3D,
    poses: LimbRuntimePose[],
    balance: BalanceResult,
    velocity: THREE.Vector3,
  ): void {
    this.clearGroup(this.comGroup);
    this.clearGroup(this.supportGroup);
    this.clearGroup(this.feetGroup);
    this.clearGroup(this.skeletonGroup);
    this.clearGroup(this.rayGroup);
    this.clearGroup(this.velocityGroup);
    this.clearGroup(this.jointLimitGroup);

    if (this.flags.centreOfMass) this.drawCentreOfMass(balance);
    if (this.flags.supportPolygon) this.drawSupportPolygon(balance.supportPolygon);
    if (this.flags.footTargets || this.flags.gaitPhase) this.drawFeet(poses);
    if (this.flags.skeleton) this.drawSkeleton(creature, root, poses);
    if (this.flags.raycasts) this.drawRaycasts(poses);
    if (this.flags.bodyVelocity) this.drawVelocity(root.position, velocity);
    if (this.flags.jointLimits) this.drawJointLimits(poses);
    this.applyVisibility();
  }

  private drawCentreOfMass(balance: BalanceResult): void {
    const material = new THREE.MeshBasicMaterial({ color: '#ff4d86', depthTest: false });
    const sphere = new THREE.Mesh(new THREE.SphereGeometry(0.085, 16, 10), material);
    sphere.position.copy(balance.centreOfMass);
    sphere.renderOrder = 20;
    this.comGroup.add(sphere);

    const projection = new THREE.Mesh(
      new THREE.RingGeometry(0.08, 0.15, 24),
      new THREE.MeshBasicMaterial({ color: '#ff4d86', side: THREE.DoubleSide, depthTest: false }),
    );
    projection.rotation.x = -Math.PI / 2;
    projection.position.copy(balance.projectedCentre);
    projection.position.y += 0.012;
    projection.renderOrder = 20;
    this.comGroup.add(projection);

    const geometry = new THREE.BufferGeometry().setFromPoints([
      balance.centreOfMass,
      balance.projectedCentre,
    ]);
    const line = new THREE.Line(
      geometry,
      new THREE.LineDashedMaterial({ color: '#ff4d86', dashSize: 0.08, gapSize: 0.05, depthTest: false }),
    );
    line.computeLineDistances();
    line.renderOrder = 20;
    this.comGroup.add(line);
  }

  private drawSupportPolygon(points: THREE.Vector3[]): void {
    if (points.length < 2) return;
    const closed = [...points.map((point) => point.clone().setY(point.y + 0.018)), points[0]!.clone().setY(points[0]!.y + 0.018)];
    const line = new THREE.Line(
      new THREE.BufferGeometry().setFromPoints(closed),
      new THREE.LineBasicMaterial({ color: '#3ef0d0', depthTest: false, transparent: true, opacity: 0.9 }),
    );
    line.renderOrder = 18;
    this.supportGroup.add(line);
  }

  private drawFeet(poses: LimbRuntimePose[]): void {
    poses.forEach((pose) => {
      const target = v3(pose.footTarget);
      const colour = pose.planted ? '#47e29b' : '#ffd45f';
      const marker = new THREE.Mesh(
        new THREE.RingGeometry(0.07, 0.12, 18),
        new THREE.MeshBasicMaterial({ color: colour, side: THREE.DoubleSide, depthTest: false }),
      );
      marker.rotation.x = -Math.PI / 2;
      marker.position.copy(target);
      marker.position.y += 0.015;
      marker.renderOrder = 19;
      marker.scale.setScalar(this.flags.gaitPhase ? 0.8 + pose.phase * 0.55 : 1);
      this.feetGroup.add(marker);
    });
  }

  private drawSkeleton(
    creature: CreatureDefinition,
    root: THREE.Object3D,
    poses: LimbRuntimePose[],
  ): void {
    const material = new THREE.LineBasicMaterial({ color: '#f5f8ff', depthTest: false, transparent: true, opacity: 0.9 });
    const bodyPoints: THREE.Vector3[] = [];
    for (const body of creature.body) {
      if (!body.parentId) continue;
      const parent = creature.body.find((entry) => entry.id === body.parentId);
      if (!parent) continue;
      bodyPoints.push(
        root.localToWorld(v3(parent.position)),
        root.localToWorld(v3(body.position)),
      );
    }
    if (bodyPoints.length) {
      const line = new THREE.LineSegments(new THREE.BufferGeometry().setFromPoints(bodyPoints), material);
      line.renderOrder = 17;
      this.skeletonGroup.add(line);
    }
    for (const pose of poses) {
      const points = pose.points.map(v3);
      if (points.length < 2) continue;
      const line = new THREE.Line(new THREE.BufferGeometry().setFromPoints(points), material.clone());
      line.renderOrder = 17;
      this.skeletonGroup.add(line);
      for (const point of points) {
        const joint = new THREE.Mesh(
          new THREE.SphereGeometry(0.035, 9, 6),
          new THREE.MeshBasicMaterial({ color: '#ffffff', depthTest: false }),
        );
        joint.position.copy(point);
        joint.renderOrder = 18;
        this.skeletonGroup.add(joint);
      }
    }
  }

  private drawRaycasts(poses: LimbRuntimePose[]): void {
    const material = new THREE.LineBasicMaterial({ color: '#71a8ff', transparent: true, opacity: 0.55, depthTest: false });
    for (const pose of poses) {
      const target = v3(pose.footTarget);
      const line = new THREE.Line(
        new THREE.BufferGeometry().setFromPoints([
          target.clone().add(new THREE.Vector3(0, 1.6, 0)),
          target.clone().add(new THREE.Vector3(0, -0.08, 0)),
        ]),
        material,
      );
      line.renderOrder = 16;
      this.rayGroup.add(line);
    }
  }

  private drawVelocity(position: THREE.Vector3, velocity: THREE.Vector3): void {
    if (velocity.lengthSq() < 0.001) return;
    const arrow = new THREE.ArrowHelper(
      velocity.clone().normalize(),
      position.clone().add(new THREE.Vector3(0, 2.2, 0)),
      Math.min(1.4, velocity.length() * 0.55),
      '#ffb34d',
      0.16,
      0.09,
    );
    this.velocityGroup.add(arrow);
  }


  private drawJointLimits(poses: LimbRuntimePose[]): void {
    for (const pose of poses) {
      const points = pose.points.map(v3);
      for (let index = 1; index < points.length - 1; index += 1) {
        const previous = points[index - 1]!;
        const current = points[index]!;
        const next = points[index + 1]!;
        const axis = next.clone().sub(previous).normalize();
        const ring = new THREE.Mesh(
          new THREE.TorusGeometry(0.095, 0.012, 6, 22, Math.PI * 1.55),
          new THREE.MeshBasicMaterial({ color: '#ffca6b', depthTest: false, transparent: true, opacity: 0.82 }),
        );
        ring.position.copy(current);
        ring.quaternion.setFromUnitVectors(new THREE.Vector3(0, 0, 1), axis);
        ring.renderOrder = 20;
        this.jointLimitGroup.add(ring);
      }
    }
  }

  private applyVisibility(): void {
    this.comGroup.visible = this.flags.centreOfMass;
    this.supportGroup.visible = this.flags.supportPolygon;
    this.feetGroup.visible = this.flags.footTargets || this.flags.gaitPhase;
    this.skeletonGroup.visible = this.flags.skeleton;
    this.rayGroup.visible = this.flags.raycasts;
    this.velocityGroup.visible = this.flags.bodyVelocity;
    this.jointLimitGroup.visible = this.flags.jointLimits;
  }

  private clearGroup(group: THREE.Group): void {
    group.traverse((object) => {
      const mesh = object as THREE.Mesh;
      mesh.geometry?.dispose();
      if (mesh.material) {
        const materials = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
        materials.forEach((material) => material.dispose());
      }
    });
    group.clear();
  }
}
