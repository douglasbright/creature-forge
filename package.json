import * as THREE from 'three';
import type {
  CreatureDefinition,
  LimbDefinition,
  LimbRuntimePose,
  RigDefinition,
  Vec3Data,
} from '../core/types';
import { attachmentNormalLocal, attachmentPointLocal, effectiveRole, getBodySegment } from '../core/anatomy';
import { solveFabrik } from '../animation/IK';
import { data3, ellipsoidSurfacePoint, v3 } from '../utils/math';

interface LimbVisual {
  segmentMeshes: THREE.Mesh[];
  jointMeshes: THREE.Mesh[];
  endEffector: THREE.Mesh;
  rootHandle: THREE.Mesh;
  baseColour: THREE.Color;
}

interface BodyVisual {
  mesh: THREE.Mesh;
  baseRotation: THREE.Euler;
}

const UP = new THREE.Vector3(0, 1, 0);

export class CreatureRenderer {
  readonly root = new THREE.Group();
  readonly visuals = new THREE.Group();
  readonly selectionHalo = new THREE.Group();
  readonly attachmentPreview = new THREE.Group();

  private creature: CreatureDefinition | null = null;
  private rig: RigDefinition | null = null;
  private bodyVisuals = new Map<string, BodyVisual>();
  private limbVisuals = new Map<string, LimbVisual>();
  private selectable: THREE.Object3D[] = [];
  private editMode = true;
  private selectedId: string | null = null;
  private readonly bodyMaterial = new THREE.MeshStandardMaterial({
    color: '#67cf79',
    roughness: 0.74,
    metalness: 0.02,
  });
  private readonly bellyMaterial = new THREE.MeshStandardMaterial({
    color: '#f5cfa6',
    roughness: 0.82,
  });
  private readonly accentMaterial = new THREE.MeshStandardMaterial({
    color: '#ff9b67',
    roughness: 0.7,
  });
  private readonly sphereGeometry = new THREE.SphereGeometry(1, 28, 18);
  private readonly jointGeometry = new THREE.SphereGeometry(1, 16, 10);

  constructor(scene: THREE.Scene) {
    this.root.name = 'Creature root';
    this.visuals.name = 'Creature visuals';
    this.selectionHalo.name = 'Selection halo';
    this.attachmentPreview.name = 'Attachment preview';
    this.root.add(this.visuals, this.selectionHalo, this.attachmentPreview);
    scene.add(this.root);
  }

  rebuild(creature: CreatureDefinition, rig: RigDefinition): LimbRuntimePose[] {
    this.creature = creature;
    this.rig = rig;
    this.disposeGroup(this.visuals);
    this.disposeGroup(this.selectionHalo);
    this.disposeGroup(this.attachmentPreview);
    this.bodyVisuals.clear();
    this.limbVisuals.clear();
    this.selectable = [];

    this.bodyMaterial.color.set(creature.palette.body);
    this.bellyMaterial.color.set(creature.palette.belly);
    this.accentMaterial.color.set(creature.palette.accent);

    this.buildBody(creature);
    this.buildDecorations(creature);
    const poses = this.buildLimbs(creature);
    this.setEditMode(this.editMode);
    this.setSelected(this.selectedId);
    return poses;
  }

  setEditMode(enabled: boolean): void {
    this.editMode = enabled;
    for (const visual of this.limbVisuals.values()) {
      visual.rootHandle.visible = enabled;
    }
    this.selectionHalo.visible = enabled;
    if (!enabled) this.attachmentPreview.clear();
  }

  setSelected(id: string | null): void {
    this.selectedId = id;
    this.selectionHalo.clear();
    if (!id) return;
    const body = this.bodyVisuals.get(id)?.mesh;
    if (body) {
      const halo = new THREE.Mesh(
        body.geometry,
        new THREE.MeshBasicMaterial({
          color: '#7df6ff',
          transparent: true,
          opacity: 0.18,
          side: THREE.BackSide,
          depthWrite: false,
        }),
      );
      halo.position.copy(body.position);
      halo.rotation.copy(body.rotation);
      halo.scale.copy(body.scale).multiplyScalar(1.08);
      halo.renderOrder = 4;
      this.selectionHalo.add(halo);
      return;
    }

    const limb = this.limbVisuals.get(id);
    if (limb) {
      limb.segmentMeshes.forEach((mesh) => {
        const outline = new THREE.Mesh(
          mesh.geometry,
          new THREE.MeshBasicMaterial({
            color: '#7df6ff',
            transparent: true,
            opacity: 0.2,
            side: THREE.BackSide,
            depthWrite: false,
          }),
        );
        outline.position.copy(mesh.position);
        outline.quaternion.copy(mesh.quaternion);
        outline.scale.copy(mesh.scale).multiplyScalar(1.13);
        this.selectionHalo.add(outline);
      });
    }
  }

  getBodyMesh(id: string): THREE.Mesh | null {
    return this.bodyVisuals.get(id)?.mesh ?? null;
  }

  getSelectableObjects(): THREE.Object3D[] {
    return this.selectable;
  }

  getBodyMeshes(): THREE.Mesh[] {
    return [...this.bodyVisuals.values()].map((entry) => entry.mesh);
  }

  getCreature(): CreatureDefinition | null {
    return this.creature;
  }

  getAttachmentWorld(limb: LimbDefinition): THREE.Vector3 {
    if (!this.creature) return this.root.position.clone();
    return this.root.localToWorld(attachmentPointLocal(this.creature, limb));
  }

  worldToLocal(point: THREE.Vector3): THREE.Vector3 {
    return this.root.worldToLocal(point.clone());
  }

  localToWorld(point: THREE.Vector3): THREE.Vector3 {
    return this.root.localToWorld(point.clone());
  }

  applyLimbPose(limbId: string, worldPoints: THREE.Vector3[]): LimbRuntimePose | null {
    const visual = this.limbVisuals.get(limbId);
    const limb = this.creature?.limbs.find((entry) => entry.id === limbId);
    if (!visual || !limb || worldPoints.length < 2) return null;
    const localPoints = worldPoints.map((point) => this.root.worldToLocal(point.clone()));

    for (let index = 0; index < visual.segmentMeshes.length; index += 1) {
      const a = localPoints[index]!;
      const b = localPoints[index + 1]!;
      this.alignSegment(visual.segmentMeshes[index]!, a, b);
    }
    visual.jointMeshes.forEach((joint, index) => {
      const point = localPoints[Math.min(index, localPoints.length - 1)]!;
      joint.position.copy(point);
    });
    const end = localPoints[localPoints.length - 1]!;
    visual.endEffector.position.copy(end);
    return {
      limbId,
      points: worldPoints.map(data3),
      footTarget: data3(worldPoints[worldPoints.length - 1]!),
      planted: false,
      phase: 0,
    };
  }


  setEndEffectorNormal(limbId: string, worldNormal: THREE.Vector3): void {
    const visual = this.limbVisuals.get(limbId);
    if (!visual || worldNormal.lengthSq() < 1e-6) return;
    const worldQuaternion = new THREE.Quaternion().setFromUnitVectors(UP, worldNormal.clone().normalize());
    const rootWorldQuaternion = new THREE.Quaternion();
    this.root.getWorldQuaternion(rootWorldQuaternion);
    visual.endEffector.quaternion.copy(rootWorldQuaternion.invert().multiply(worldQuaternion));
  }

  updateSecondaryMotion(time: number, speed: number, turn: number, balanceError: THREE.Vector3): void {
    if (!this.creature) return;
    const tails = this.creature.body.filter((segment) => segment.kind === 'tail');
    tails.forEach((segment, index) => {
      const visual = this.bodyVisuals.get(segment.id);
      if (!visual) return;
      const lag = index * 0.55;
      visual.mesh.rotation.copy(visual.baseRotation);
      visual.mesh.rotation.y +=
        Math.sin(time * (2.2 + speed * 0.35) - lag) * (0.08 + speed * 0.035) - turn * 0.2 - balanceError.x * 0.16;
      visual.mesh.rotation.x += Math.cos(time * 1.7 - lag) * (0.035 + speed * 0.015);
    });

    const head = this.creature.body.find((segment) => segment.kind === 'head');
    if (head) {
      const visual = this.bodyVisuals.get(head.id);
      if (visual) {
        visual.mesh.rotation.copy(visual.baseRotation);
        visual.mesh.rotation.y -= turn * 0.12;
        visual.mesh.rotation.z -= balanceError.x * 0.06;
      }
    }
  }

  showAttachmentPreview(point: THREE.Vector3 | null, mirrorPoint: THREE.Vector3 | null = null): void {
    this.attachmentPreview.clear();
    if (!point) return;
    const material = new THREE.MeshBasicMaterial({ color: '#6cfff0', transparent: true, opacity: 0.82 });
    const create = (worldPoint: THREE.Vector3) => {
      const marker = new THREE.Mesh(new THREE.SphereGeometry(0.105, 18, 10), material);
      marker.position.copy(this.root.worldToLocal(worldPoint.clone()));
      this.attachmentPreview.add(marker);
    };
    create(point);
    if (mirrorPoint) create(mirrorPoint);
  }

  createCandidateMarkers(creature: CreatureDefinition, bodyId: string | null): void {
    this.attachmentPreview.clear();
    const material = new THREE.MeshBasicMaterial({ color: '#79fff3', transparent: true, opacity: 0.45 });
    const bodySegments = creature.body.filter((segment) =>
      bodyId ? segment.id === bodyId : segment.kind === 'torso' || segment.kind === 'neck',
    );
    for (const body of bodySegments) {
      const centre = v3(body.position);
      const scale = v3(body.scale);
      const quaternion = new THREE.Quaternion().setFromEuler(
        new THREE.Euler(body.rotation.x, body.rotation.y, body.rotation.z),
      );
      for (let ring = 0; ring < 3; ring += 1) {
        const vertical = -0.55 + ring * 0.55;
        for (let side = 0; side < 8; side += 1) {
          const angle = (side / 8) * Math.PI * 2;
          const normal = new THREE.Vector3(Math.cos(angle), vertical, Math.sin(angle)).normalize();
          const point = ellipsoidSurfacePoint(new THREE.Vector3(), scale, normal)
            .applyQuaternion(quaternion)
            .add(centre);
          const marker = new THREE.Mesh(new THREE.SphereGeometry(0.045, 10, 7), material);
          marker.position.copy(point);
          this.attachmentPreview.add(marker);
        }
      }
    }
  }

  private buildBody(creature: CreatureDefinition): void {
    for (const body of creature.body) {
      const material = body.kind === 'head' ? this.bodyMaterial.clone() : this.bodyMaterial;
      if (body.colour) material.color.set(body.colour);
      const mesh = new THREE.Mesh(this.sphereGeometry, material);
      mesh.name = body.name;
      mesh.position.copy(v3(body.position));
      mesh.rotation.set(body.rotation.x, body.rotation.y, body.rotation.z);
      mesh.scale.copy(v3(body.scale));
      mesh.castShadow = true;
      mesh.receiveShadow = true;
      mesh.userData = { selectable: 'body', id: body.id };
      this.visuals.add(mesh);
      this.bodyVisuals.set(body.id, { mesh, baseRotation: mesh.rotation.clone() });
      this.selectable.push(mesh);

      if (body.parentId) {
        const parent = getBodySegment(creature, body.parentId);
        if (parent) this.buildBodyBridge(parent, body, creature.palette.body);
      }

      if (body.kind === 'torso' && body.scale.y > 0.55) {
        const belly = new THREE.Mesh(this.sphereGeometry, this.bellyMaterial);
        belly.position.copy(mesh.position).add(new THREE.Vector3(0, -body.scale.y * 0.1, body.scale.z * 0.77));
        belly.scale.set(body.scale.x * 0.58, body.scale.y * 0.64, body.scale.z * 0.17);
        belly.rotation.copy(mesh.rotation);
        belly.castShadow = true;
        belly.receiveShadow = true;
        belly.userData = { selectable: 'body', id: body.id };
        this.visuals.add(belly);
        this.selectable.push(belly);
      }
    }
  }

  private buildBodyBridge(parent: CreatureDefinition['body'][number], child: CreatureDefinition['body'][number], colour: string): void {
    const a = v3(parent.position);
    const b = v3(child.position);
    const distance = a.distanceTo(b);
    if (distance < 0.1) return;
    const radius = Math.max(
      0.08,
      Math.min(parent.scale.x, parent.scale.y, parent.scale.z, child.scale.x, child.scale.y, child.scale.z) *
        (child.kind === 'tail' ? 0.55 : 0.7),
    );
    const geometry = new THREE.CylinderGeometry(radius * 0.86, radius, 1, 16, 1, false);
    const material = new THREE.MeshStandardMaterial({ color: colour, roughness: 0.76 });
    const bridge = new THREE.Mesh(geometry, material);
    bridge.userData = { selectable: 'body', id: child.id };
    bridge.castShadow = true;
    bridge.receiveShadow = true;
    this.alignSegment(bridge, a, b);
    this.visuals.add(bridge);
    this.selectable.push(bridge);
  }

  private buildDecorations(creature: CreatureDefinition): void {
    for (const decoration of creature.decorations) {
      const body = getBodySegment(creature, decoration.bodyId);
      if (!body) continue;
      const normal = v3(decoration.normal).normalize();
      const quaternion = new THREE.Quaternion().setFromEuler(
        new THREE.Euler(body.rotation.x, body.rotation.y, body.rotation.z),
      );
      const rotatedNormal = normal.clone().applyQuaternion(quaternion);
      const localSurface = ellipsoidSurfacePoint(new THREE.Vector3(), v3(body.scale), normal)
        .applyQuaternion(quaternion)
        .add(v3(body.position));

      if (decoration.kind === 'eye') {
        const white = new THREE.Mesh(
          this.sphereGeometry,
          new THREE.MeshStandardMaterial({ color: decoration.colour ?? '#ffffff', roughness: 0.44 }),
        );
        white.position.copy(localSurface).addScaledVector(rotatedNormal, 0.035);
        white.scale.copy(v3(decoration.scale));
        white.castShadow = true;
        white.userData = { selectable: 'decoration', id: decoration.id };
        this.visuals.add(white);
        this.selectable.push(white);

        const pupil = new THREE.Mesh(
          this.sphereGeometry,
          new THREE.MeshStandardMaterial({ color: creature.palette.eyes, roughness: 0.32 }),
        );
        pupil.position.copy(localSurface).addScaledVector(rotatedNormal, 0.14);
        pupil.scale.copy(v3(decoration.scale).multiplyScalar(0.48));
        pupil.scale.z *= 0.6;
        this.visuals.add(pupil);
      } else {
        const scale = v3(decoration.scale);
        const material = new THREE.MeshStandardMaterial({
          color: decoration.colour ?? creature.palette.accent,
          roughness: 0.72,
        });
        let geometry: THREE.BufferGeometry;
        if (decoration.kind === 'horn') {
          geometry = new THREE.ConeGeometry(Math.max(0.04, scale.x), Math.max(0.12, scale.y * 2), 14, 2);
        } else if (decoration.kind === 'ear') {
          geometry = new THREE.ConeGeometry(Math.max(0.05, scale.x), Math.max(0.14, scale.y * 2), 12, 2);
        } else {
          geometry = new THREE.ConeGeometry(Math.max(0.04, scale.x), Math.max(0.16, scale.z * 1.7), 10, 2);
        }
        const attachment = new THREE.Mesh(geometry, material);
        const extent = decoration.kind === 'fin' ? scale.z * 0.65 : scale.y * 0.8;
        attachment.position.copy(localSurface).addScaledVector(rotatedNormal, extent);
        attachment.quaternion.setFromUnitVectors(UP, rotatedNormal);
        if (decoration.kind === 'ear') attachment.scale.z = Math.max(0.3, scale.z / Math.max(0.01, scale.x));
        if (decoration.kind === 'fin') attachment.scale.z = 0.34;
        attachment.castShadow = true;
        attachment.receiveShadow = true;
        attachment.userData = { selectable: 'decoration', id: decoration.id };
        this.visuals.add(attachment);
        this.selectable.push(attachment);
      }
    }

    const head = creature.body.find((entry) => entry.kind === 'head');
    if (head) {
      const mouth = new THREE.Mesh(
        new THREE.TorusGeometry(Math.min(0.2, head.scale.x * 0.34), 0.025, 8, 24, Math.PI),
        new THREE.MeshStandardMaterial({ color: '#4c3441', roughness: 0.68 }),
      );
      mouth.position.copy(v3(head.position));
      mouth.position.y -= head.scale.y * 0.2;
      mouth.position.z += head.scale.z * 0.92;
      mouth.rotation.z = Math.PI;
      mouth.scale.y = 0.65;
      this.visuals.add(mouth);
    }
  }

  private buildLimbs(creature: CreatureDefinition): LimbRuntimePose[] {
    const poses: LimbRuntimePose[] = [];
    for (const limb of creature.limbs) {
      const colour = new THREE.Color(limb.colour ?? creature.palette.body);
      const visual: LimbVisual = {
        segmentMeshes: [],
        jointMeshes: [],
        endEffector: new THREE.Mesh(),
        rootHandle: new THREE.Mesh(),
        baseColour: colour,
      };
      limb.segments.forEach((segment, index) => {
        const nextRadius = segment.radius * segment.taper;
        const geometry = new THREE.CylinderGeometry(nextRadius, segment.radius, 1, 14, 2, false);
        const material = new THREE.MeshStandardMaterial({
          color: colour,
          roughness: 0.76,
          metalness: 0.01,
        });
        const mesh = new THREE.Mesh(geometry, material);
        mesh.castShadow = true;
        mesh.receiveShadow = true;
        mesh.userData = { selectable: 'limb', id: limb.id, segmentIndex: index };
        visual.segmentMeshes.push(mesh);
        this.visuals.add(mesh);
        this.selectable.push(mesh);

        const joint = new THREE.Mesh(
          this.jointGeometry,
          new THREE.MeshStandardMaterial({ color: colour, roughness: 0.78 }),
        );
        joint.scale.setScalar(segment.radius * 1.08);
        joint.castShadow = true;
        joint.userData = { selectable: 'limb', id: limb.id, segmentIndex: index };
        visual.jointMeshes.push(joint);
        this.visuals.add(joint);
        this.selectable.push(joint);
      });

      const effectorMaterial =
        effectiveRole(creature, limb) === 'manipulator' || effectiveRole(creature, limb) === 'balance'
          ? this.bellyMaterial.clone()
          : new THREE.MeshStandardMaterial({ color: colour, roughness: 0.82 });
      const effector = new THREE.Mesh(this.sphereGeometry, effectorMaterial);
      effector.scale.copy(v3(limb.endEffectorScale));
      effector.castShadow = true;
      effector.receiveShadow = true;
      effector.userData = { selectable: 'limb', id: limb.id, effector: true };
      visual.endEffector = effector;
      this.visuals.add(effector);
      this.selectable.push(effector);

      const rootHandle = new THREE.Mesh(
        new THREE.SphereGeometry(0.085, 16, 10),
        new THREE.MeshBasicMaterial({ color: '#65f6e6', transparent: true, opacity: 0.75, depthTest: false }),
      );
      rootHandle.renderOrder = 8;
      rootHandle.position.copy(attachmentPointLocal(creature, limb));
      rootHandle.userData = { selectable: 'limb-root', id: limb.id };
      visual.rootHandle = rootHandle;
      this.visuals.add(rootHandle);
      this.selectable.push(rootHandle);
      this.limbVisuals.set(limb.id, visual);

      const rest = this.createRestPose(creature, limb);
      const world = rest.map((point) => this.root.localToWorld(point.clone()));
      this.applyLimbPose(limb.id, world);
      poses.push({
        limbId: limb.id,
        points: world.map(data3),
        footTarget: data3(world[world.length - 1]!),
        planted: effectiveRole(creature, limb) === 'locomotion' || effectiveRole(creature, limb) === 'support',
        phase: 0,
      });
    }
    return poses;
  }

  private createRestPose(creature: CreatureDefinition, limb: LimbDefinition): THREE.Vector3[] {
    const root = attachmentPointLocal(creature, limb);
    const lengths = limb.segments.map((segment) => segment.length);
    const total = lengths.reduce((sum, length) => sum + length, 0);
    const role = effectiveRole(creature, limb);
    const normal = attachmentNormalLocal(creature, limb);
    let target: THREE.Vector3;
    if (role === 'locomotion' || role === 'support') {
      target = new THREE.Vector3(root.x + normal.x * 0.14, 0.04, root.z + normal.z * 0.14);
    } else if (role === 'manipulator' || role === 'balance') {
      target = root
        .clone()
        .add(new THREE.Vector3(normal.x * 0.22, -total * 0.82, 0.14 + Math.abs(normal.z) * 0.08));
    } else {
      target = root.clone().addScaledVector(normal, total * 0.88);
    }
    return solveFabrik(root, target, lengths, v3(limb.bendDirection));
  }

  private alignSegment(mesh: THREE.Object3D, a: THREE.Vector3, b: THREE.Vector3): void {
    const direction = b.clone().sub(a);
    const distance = direction.length();
    mesh.position.copy(a).add(b).multiplyScalar(0.5);
    if (distance > 1e-5) mesh.quaternion.setFromUnitVectors(UP, direction.normalize());
    mesh.scale.y = distance;
  }

  private disposeGroup(group: THREE.Group): void {
    for (const child of [...group.children]) {
      group.remove(child);
      child.traverse((object) => {
        const mesh = object as THREE.Mesh;
        if (mesh.geometry && mesh.geometry !== this.sphereGeometry && mesh.geometry !== this.jointGeometry) {
          mesh.geometry.dispose();
        }
        if (mesh.material) {
          const materials = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
          for (const material of materials) {
            if (
              material !== this.bodyMaterial &&
              material !== this.bellyMaterial &&
              material !== this.accentMaterial
            ) {
              material.dispose();
            }
          }
        }
      });
    }
  }
}
